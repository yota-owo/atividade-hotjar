# ==========================================
# A RUNA — Variáveis de Ambiente (TEMPLATE)
# ==========================================
# Copie este arquivo para .env e preencha com valores reais.
# O .env real NÃO deve ir para o git.
# ==========================================

# Chave secreta usada para assinar os JWTs.
# Use uma string longa e aleatória (>= 32 caracteres recomendado).
# Sugestão para gerar: `openssl rand -base64 48`
JWT_SECRET=troque_para_uma_chave_aleatoria_longa_e_unica
